end
```

### Modelo Complejo
```ruby
require 'rails_helper'

RSpec.describe Applicant, type: :model do
  let(:uniq_applicant) { create(:uniq_applicant) }
  let(:applicant) { create(:applicant, uniq_applicant: uniq_applicant) }
  
  it_behaves_like 'soft_delete'
  
  it 'does have a valid factory' do
    expect(applicant).to be_valid
  end
  
  describe 'validations' do
    it { is_expected.to validate_presence_of(:first_name) }
    it { is_expected.to validate_presence_of(:last_name) }
  end
  
  describe 'callbacks' do
    it { is_expected.to callback(:movement_to_new_list).before(:validation) }
    it { is_expected.to callback(:send_form_automatically).after(:create) }
    it { is_expected.to callback(:parse_curriculum).after(:save) }
  end
  
  describe 'ActiveRecord associations' do
    it { is_expected.to have_many(:logs) }
    it { is_expected.to have_many(:applicant_files).dependent(:destroy) }
    it { is_expected.to have_one(:board).through(:list) }
    it { is_expected.to have_one(:selection_process).through(:board) }
    it { is_expected.to belong_to(:list) }
    it { is_expected.to belong_to(:consultant).optional }
    it { is_expected.to belong_to(:uniq_applicant).optional }
  end
  
  describe 'scopes' do
    it { expect(described_class).to respond_to(:active) }
    it { expect(described_class).to respond_to(:disqualified) }
    it { expect(described_class).to respond_to(:filter_by_organization) }
  end
  
  describe 'delegations' do
    it { is_expected.to delegate_method(:organization_id).to(:selection_process) }
  end
  
  describe 'concerns' do
    describe 'EmailValidatable' do
      describe '#downcase_email' do
        it 'converts email to lowercase' do
          applicant = create(:applicant, email: 'TEST@EXAMPLE.COM')
          expect(applicant.email).to eq('test@example.com')
        end
      end
    end
    
    describe 'Trackable' do
      it { is_expected.to respond_to(:track_create) }
      it { is_expected.to respond_to(:track_update) }
    end
  end
  
  describe 'public instance methods' do
    describe '#full_name' do
      it 'returns concatenated first and last name' do
        applicant = build(:applicant, first_name: 'John', last_name: 'Doe')
        expect(applicant.full_name).to eq('John Doe')
      end
    end
    
    describe '#real_email?' do
      context 'when email is from rankmiats.com' do
        it 'returns false' do
          applicant = build(:applicant, email: 'fake@rankmiats.com')
          expect(applicant.real_email?).to be false
        end
      end
      
      context 'when email is real' do
        it 'returns true' do
          applicant = build(:applicant, email: 'real@example.com')
          expect(applicant.real_email?).to be true
        end
      end
    end
    
    describe '#calculate_score' do
      it 'returns integer score' do
        expect(applicant.calculate_score).to be_an(Integer)
      end
      
      it 'returns score between 0 and 100' do
        score = applicant.calculate_score
        expect(score).to be >= 0
        expect(score).to be <= 100
      end
    end
  end
end
```

## Checklist para Model Specs

Antes de finalizar tus tests, verifica:

- [ ] Incluye `require 'rails_helper'`
- [ ] Define `type: :model`
- [ ] Primer test valida factory
- [ ] Usa Shoulda Matchers para associations/validations
- [ ] Sigue el orden de sections recomendado
- [ ] Testea solo existencia de scopes (salvo excepciones)
- [ ] Testea todos los métodos públicos
- [ ] NO testea métodos privados
- [ ] Usa `build` o `build_stubbed` cuando sea posible
- [ ] Usa `create` solo cuando necesites persistencia
- [ ] Nombres descriptivos para tests
- [ ] Tests independientes y aislados
- [ ] Evita lógica compleja en los tests
- [ ] Usa shared examples para comportamiento común

## Anti-Patrones a Evitar

❌ **No hagas esto:**
```ruby
# No testear métodos privados
it 'calls private method' do
  model.send(:private_method)
end

# No testear implementación de scopes
it 'scope filters by status' do
  expect(User.active.to_sql).to include('WHERE status = 1')
end

# No usar create cuando build es suficiente
it 'validates name presence' do
  user = create(:user, name: nil)  # Innecesario usar create
  expect(user).not_to be_valid
end

# No testear Rails framework
it 'has created_at and updated_at' do
  expect(user).to respond_to(:created_at)
end

# Tests dependientes del orden
it 'step 1' do
  @user = create(:user)
end

it 'step 2' do
  expect(@user.active?).to be true
end
```

✅ **Haz esto:**
```ruby
# Testea interfaz pública
it 'has public method' do
  expect(model).to respond_to(:public_method)
end

# Testea comportamiento, no implementación
describe '.active' do
  it { expect(described_class).to respond_to(:active) }
end

# Usa build para validaciones
it 'validates name presence' do
  user = build(:user, name: nil)
  expect(user).not_to be_valid
end

# Testea tu código, no Rails
it 'calculates custom field' do
  expect(user.custom_calculation).to eq(expected_value)
end

# Tests independientes
it 'validates user' do
  user = create(:user)
  expect(user.active?).to be true
end
```

## Optimización de Performance

```ruby
# Usa build_stubbed cuando no necesites BD
let(:user) { build_stubbed(:user) }

# Usa let_it_be para datos compartidos
let_it_be(:organization) { create(:organization) }

# Crea solo lo necesario
let(:user) { build(:user, organization: build(:organization)) }
# en vez de:
let(:organization) { create(:organization) }
let(:user) { create(:user, organization: organization) }
```

