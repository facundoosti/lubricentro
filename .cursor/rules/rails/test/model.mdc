### Modelo Simple
```ruby
require 'rails_helper'

RSpec.describe Tag, type: :model do
  include_context 'with instanced described class'
  
  it 'does have a valid factory' do
    expect(tag).to be_valid
  end
  
  describe 'validations' do
    it { is_expected.to validate_presence_of(:name) }
    it { is_expected.to validate_uniqueness_of(:name).scoped_to(:organization_id) }
  end
  
  describe 'ActiveRecord associations' do
    it { is_expected.to belong_to(:organization) }
    it { is_expected.to have_many(:applicant_tags).dependent(:destroy) }
    it { is_expected.to have_many(:applicants).through(:applicant_tags) }
  end
  
  describe 'scopes' do
    it { expect(described_class).to respond_to(:active) }
    it { expect(described_class).to respond_to(:by_type) }
  end
  
  describe 'public instance methods' do
