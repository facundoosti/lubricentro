      end
    end
  end
end
```

### 7. Aggregator Services

```ruby
RSpec.describe Dashboard::Statistics, type: :service do
  let(:organization) { create(:organization) }
  let(:service) { described_class.new(organization) }
  
  describe '#call' do
    let!(:active_processes) { create_list(:selection_process, 3, :active, organization: organization) }
    let!(:closed_processes) { create_list(:selection_process, 2, :closed, organization: organization) }
    let!(:applicants) { create_list(:applicant, 10, organization: organization) }
    
    it 'returns statistics hash' do
      result = service.call
      
      expect(result).to include(
        active_processes: 3,
        closed_processes: 2,
        total_applicants: 10
      )
    end
    
    it 'calculates average applicants per process' do
      result = service.call
      expect(result[:avg_applicants_per_process]).to eq(2)
    end
  end
end
```

## Testing con Transacciones

Para servicios que usan transacciones:

```ruby
describe 'transaction handling' do
  context 'when all operations succeed' do
    it 'commits transaction' do
      expect { service.call }.to change(User, :count).by(1)
        .and change(Profile, :count).by(1)
    end
  end
  
  context 'when operation fails' do
    before do
      allow_any_instance_of(Profile).to receive(:save!).and_raise(ActiveRecord::RecordInvalid)
    end
    
    it 'rolls back all changes' do
      expect { service.call rescue nil }.not_to change(User, :count)
    end
  end
end
```

## Performance Testing

Para servicios que deben ser eficientes:

```ruby
describe 'performance' do
  it 'executes in reasonable time' do
    expect { service.call }.to perform_under(100).ms
  end
  
  it 'does not create N+1 queries' do
    create_list(:user, 10, :with_organization)
    
    expect { service.call }.to perform_constant_number_of_queries
  end
end
```

## Ejemplos Completos

### Servicio Simple
```ruby
# frozen_string_literal: true

require 'rails_helper'

RSpec.describe Api::V1::Consultants::CreateService, type: :service do
  describe '#perform' do
    let_it_be(:organization) { create(:organization) }
    let(:params) { { name: "Example", organization_id: organization.id } }
    let(:service) { described_class.new(params) }
    
    it 'returns a Consultant instance' do
      expect(service.perform).to be_kind_of(Consultant)
    end
    
    it 'creates a new consultant' do
      expect { service.perform }.to change(Consultant, :count).by(1)
    end
    
    it 'sets correct attributes' do
      consultant = service.perform
      expect(consultant.name).to eq("Example")
      expect(consultant.organization).to eq(organization)
    end
  end
end
```

### Servicio Complejo
```ruby
# frozen_string_literal: true

require 'rails_helper'

RSpec.describe SelectionProcesses::ExternalCreate, type: :service do
  subject(:service) { described_class.new(params, current_user) }
  
  let(:organization) { create(:organization) }
  let(:current_user) { create(:user, :admin, organization: organization) }
  let(:valid_params) do
    {
      name: 'Software Engineer',
      description: 'Ruby on Rails position',
      areas: ['engineering'],
      requirements: { experience: 3 }
    }
  end
  
  describe '#call' do
    subject(:call) { service.call }
    
    context 'when all params are valid' do
      let(:params) { valid_params }
      
      it 'creates a selection process' do
        expect { call }.to change(SelectionProcess, :count).by(1)
      end
      
      it 'creates default boards' do
        expect { call }.to change(Board, :count).by(1)
      end
      
      it 'creates default lists' do
        expect { call }.to change(List, :count).by(3)
      end
      
      it 'assigns organization' do
        result = call
        expect(result.organization).to eq(organization)
      end
      
      it 'sets created_by user' do
        result = call
        expect(result.created_by).to eq(current_user)
      end
      
      it 'enqueues notification job' do
        expect { call }.to have_enqueued_job(ProcessCreatedNotificationJob)
      end
      
      it 'creates audit log' do
        expect { call }.to change(AuditLog, :count).by(1)
      end
    end
    
    context 'when name is missing' do
      let(:params) { valid_params.except(:name) }
      
      it 'raises validation error' do
        expect { call }.to raise_error(ActiveRecord::RecordInvalid)
      end
      
      it 'does not create any records' do
        expect {
          call rescue nil
        }.not_to change(SelectionProcess, :count)
      end
    end
    
    context 'when organization is invalid' do
      let(:current_user) { create(:user, organization: nil) }
      
      it 'raises error' do
        expect { call }.to raise_error(NoOrganizationError)
      end
    end
    
    context 'when user lacks permissions' do
      let(:current_user) { create(:user, :employee) }
      
      it 'raises authorization error' do
        expect { call }.to raise_error(NotAuthorizedError)
      end
    end
    
    context 'when external API integration is enabled' do
      before do
        organization.update(reqlut_enabled: true)
        stub_request(:post, 'https://api.reqlut.com/jobs')
          .to_return(status: 200, body: { id: '123' }.to_json)
      end
      
      it 'publishes to external API' do
        call
        expect(WebMock).to have_requested(:post, 'https://api.reqlut.com/jobs')
      end
      
      it 'stores external ID' do
        result = call
        expect(result.reqlut_id).to eq('123')
      end
    end
  end
end
```

## Checklist para Service Specs

Antes de finalizar tus tests, verifica:

- [ ] Incluye `require 'rails_helper'`
- [ ] Define `type: :service`
- [ ] Define service como subject
- [ ] Testea el happy path primero
- [ ] Testea casos de error
- [ ] Testea edge cases
- [ ] Testea side effects (jobs, emails, broadcasts)
- [ ] Mockea dependencias externas
- [ ] Usa factories para objetos de BD
- [ ] Usa doubles para objetos simples
- [ ] Nombres descriptivos para contexts
- [ ] Tests independientes
- [ ] Verifica el tipo del resultado
- [ ] Testea transacciones si aplica

## Anti-Patrones a Evitar

❌ **No hagas esto:**
```ruby
# No testear lógica de Rails/ActiveRecord
it 'saves to database' do
  service.call
  expect(User.count).to eq(1)
end

# No testear implementación interna
it 'calls private method' do
  expect(service).to receive(:private_method)
  service.call
end

# No crear datos innecesarios
let!(:user1) { create(:user) }
let!(:user2) { create(:user) }
# ... cuando no se usan

# Tests vagos
it 'works' do
  expect(service.call).to be_truthy
end

# Múltiples responsabilidades en un test
it 'does everything' do
  result = service.call
  expect(result).to be_present
  expect(User.count).to eq(1)
  expect(Email.last.subject).to eq('Welcome')
  expect(result.status).to eq('active')
end
```

✅ **Haz esto:**
```ruby
# Testea el contrato del servicio
it 'returns created user' do
  result = service.call
  expect(result).to be_a(User)
end

# Testea interfaz pública
it 'creates user successfully' do
  expect { service.call }.to change(User, :count).by(1)
end

# Usa let para lazy loading
let(:user) { create(:user) }  # solo se crea si se usa

# Tests específicos y descriptivos
it 'returns User instance with correct attributes' do
  result = service.call
  expect(result).to be_a(User)
  expect(result.persisted?).to be true
end

# Una expectativa por test
it 'creates a user' do
  expect { service.call }.to change(User, :count).by(1)
end

it 'sends welcome email' do
  expect { service.call }.to have_enqueued_job(WelcomeEmailJob)
end

it 'returns active user' do
  result = service.call
  expect(result.status).to eq('active')
end
```

## Notas Finales

- **Aislamiento**: Los tests de servicios deben ser rápidos y aislados
- **Mocks vs Factories**: Elige según el contexto (ver sección de estrategias)
- **Cobertura**: Enfócate en casos importantes, no en 100% de cobertura
- **Legibilidad**: El código del test es documentación viva
- **Mantenibilidad**: Tests simples y claros son más valiosos que tests complejos

